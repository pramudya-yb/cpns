{
  "name": "pram",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.5.5",
      "next-themes": "^0.4.6",
      "@trpc/client": "^11.16.0",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=!.",
    "build": "turbo build --filter=!.",
    "test": "turbo test --filter=!.",
    "check-types": "turbo check-types --filter=!.",
    "compress:og": "bun scripts/compress-og-image.ts",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @pram/db db:push",
    "db:studio": "turbo -F @pram/db db:studio",
    "db:generate": "turbo -F @pram/db db:generate",
    "db:migrate": "turbo -F @pram/db db:migrate",
    "db:seed": "turbo -F @pram/db db:seed",
    "db:start": "turbo -F @pram/db db:start",
    "db:watch": "turbo -F @pram/db db:watch",
    "db:stop": "turbo -F @pram/db db:stop",
    "db:down": "turbo -F @pram/db db:down"
  },
  "dependencies": {
    "@pram/env": "workspace:*",
    "dotenv": "catalog:",
    "react-joyride": "^3.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pram/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14",
  "license": "AGPL-3.0"
}
